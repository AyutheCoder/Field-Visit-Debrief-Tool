# Server environment variables

# Port the API server listens on
PORT=4000

# SQLite database location (relative to /server), powered by node:sqlite
DATABASE_URL="file:./data/dev.db"

# Comma-separated list of allowed CORS origins (the client dev URL(s))
CLIENT_ORIGIN="http://localhost:5173,http://localhost:5174"

# Auth (prototype): secret used to sign session tokens + shared demo password
AUTH_SECRET="change-me-to-a-long-random-string"
AUTH_DEMO_PASSWORD="demo1234"

# AI provider (Google Gemini) - leave blank to disable AI features
GEMINI_API_KEY=""

# Optional AI overrides
# Chat model used for debrief generation and transcription
GEMINI_MODEL="gemini-2.0-flash"
# Embedding model used for pattern detection and semantic search
GEMINI_EMBED_MODEL="text-embedding-004"